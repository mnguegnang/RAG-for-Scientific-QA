    "# Cross-Encoder Experiment\n",
    "from sentence_transformers import CrossEncoder\n",
    "\n",
    "# 1. Load Model\n",
    "print(\"Loading Cross-Encoder...\")\n",
    "reranker = CrossEncoder('cross-encoder/ms-marco-MiniLM-L-6-v2')\n",
    "\n",
    "# 2. Scenario: Nuance\n",
    "# Query: \"How does learning rate affect instability?\"\n",
    "query = \"How does learning rate affect instability?\"\n",
    "\n",
    "# 3. Candidates (Simulating retrieval results)\n",
    "passages = [\n",
    "    # A: Contains keywords, but talks about the wrong thing (Performance speed)\n",
    "    \"A higher learning rate improves the speed of convergence in the initial phases.\",\n",
    "    \n",
    "    # B: Actual Answer (Discusses instability/divergence)\n",
    "    \"If the learning rate is too large, the loss function may oscillate or diverge, causing instability.\",\n",
    "    \n",
    "    # C: Irrelevant but mentions \"learning\"\n",
    "    \"We are learning to build better models using rate limiting.\"\n",
    "]\n",
    "\n",
    "# 4. Prepare Input\n",
    "# Cross-Encoder expects pairs: [[Query, Passage1], [Query, Passage2]...]\n",
    "model_inputs = [[query, p] for p in passages]\n",
    "\n",
    "# 5. Score\n",
    "scores = reranker.predict(model_inputs)\n",
    "\n",
    "# 6. Display\n",
    "results = sorted(zip(passages, scores), key=lambda x: x[1], reverse=True)\n",
    "\n",
    "print(f\"Query: {query}\\n\")\n",
    "for passage, score in results:\n",
    "    print(f\"Score: {score:.4f} | Text: {passage}\")"
   ]
